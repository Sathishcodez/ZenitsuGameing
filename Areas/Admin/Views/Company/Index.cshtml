

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Companies</h2>
    <a class="btn btn-primary" asp-controller="Company" asp-action="Upsert"> <i class="bi bi-plus-circle me-1"></i>Add Company</a>
</div>



<table id="tblData" class="table table-bordered table-striped" width="100%">
    <thead>
        <tr>
            <th>Name</th>
            <th>Adress</th>
            <th>City</th>
            <th>State</th>
            <th>PostalCode</th>
            <th>PhoneNumber</th>
        </tr>
    </thead>
</table>


@section Scripts {
    <script src="~/js/Company.js"></script>
}



