@model IEnumerable<Product>

<style>
    .product-card {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .product-image {
        width: 100%;
        height: 300px;
        object-fit: cover;
        border-radius: 0.375rem;
    }

    .card-body {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .product-title {
        min-height: 4rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-creator {
        min-height: 2rem;
    }

    /* Ensure equal height cards in the same row */
    .row-eq-height {
        display: flex;
        flex-wrap: wrap;
    }

    .row-eq-height > [class*='col-'] {
        display: flex;
    }
</style>

<div class="row pb-3 row-eq-height">
    @foreach (var product in Model)
    {
        <div class="col-lg-3 col-sm-6 mb-4">
            <div class="card border-0 p-3 shadow border-top border-5 rounded product-card">
                <img src="@product.ImageUrl" alt="@product.Title" class="product-image" />
                <div class="card-body pb-0">
                    <div class="pl-1 product-title">
                        <p class="card-title h5 text-dark opacity-75 text-uppercase text-center mb-2">@product.Title</p>
                    </div>
                    <div class="pl-1 product-creator">
                        <p class="card-title text-warning text-center mb-2">by <b>@product.Creator</b></p>
                    </div>
                    <div class="pl-1">
                        <p class="text-dark text-opacity-75 text-center mb-0">
                            List Price:
                            <span class="text-decoration-line-through">
                                @product.Price.ToString("c")
                            </span>
                        </p>
                    </div>
                    <div class="pl-1">
                        <p class="text-dark text-opacity-75 text-center mb-3">
                            As low as:
                            <span>
                                @product.Price100.ToString("c")
                            </span>
                        </p>
                    </div>
                </div>
                <div class="mt-auto px-3 pb-3">
                    <a asp-action="Details"
                       asp-route-Id="@product.Id"
                       class="btn btn-primary bg-gradient border-0 form-control">
                        Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
